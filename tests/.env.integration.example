# Integration test configuration
# Copy to tests/.env.integration and fill in values
# This file is gitignored — never commit with real credentials

# ---------------------------------------------------------------------------
# AWS Secrets Manager (account: hypersec-internet-services, ap-southeast-2)
# ---------------------------------------------------------------------------

HYPERI_TEST_AWS_REGION=ap-southeast-2
HYPERI_TEST_AWS_SECRET_NAME=hyperi-pylib-test

# Credentials via SSO (run before tests):
#   aws sso login --profile hypersec-internet-services
#   eval $(aws configure export-credentials --profile hypersec-internet-services --format env)
#
# Or set directly:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...

# ---------------------------------------------------------------------------
# GCP Secret Manager (project: hyperi-dfe)
# ---------------------------------------------------------------------------

HYPERI_TEST_GCP_PROJECT_ID=hyperi-dfe
HYPERI_TEST_GCP_SECRET_NAME=hyperi-pylib-test

# Credentials via ADC (run once):
#   gcloud auth application-default login

# ---------------------------------------------------------------------------
# Azure Key Vault (vault: hyperi-pylib-test)
# ---------------------------------------------------------------------------

HYPERI_TEST_AZURE_VAULT_URL=https://hyperi-pylib-test.vault.azure.net/
HYPERI_TEST_AZURE_SECRET_NAME=hyperi-pylib-test

# Credentials via Azure CLI (run once):
#   az login
#
# Note: if AZURE_CLIENT_SECRET is set in your environment with a stale value,
# unset it before running tests — it overrides CLI auth:
#   unset AZURE_CLIENT_SECRET

# ---------------------------------------------------------------------------
# OpenBao / Vault (devex environment)
# ---------------------------------------------------------------------------

HYPERI_TEST_VAULT_ADDR=https://bao.devex.hyperi.io:8200
HYPERI_TEST_VAULT_TOKEN=<token-from-openbao>
HYPERI_TEST_VAULT_PATH=secret/data/hyperi-pylib-test
HYPERI_TEST_VAULT_KEY=api_key
