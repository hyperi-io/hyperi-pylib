import importlib

def test_template_core_imports():
    pkg = importlib.import_module("{{ package_name }}.core")
    assert hasattr(pkg, "TemplateClass")


def test_template_class_basic():
    core = importlib.import_module("{{ package_name }}.core")
    TemplateClass = getattr(core, "TemplateClass")
    obj = TemplateClass(name="example")
    assert obj is not None
    # get_info may exist based on template; tolerate if missing
    if hasattr(obj, "get_info"):
        info = obj.get_info()
        assert isinstance(info, dict) or info is not None
