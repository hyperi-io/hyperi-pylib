# CI/CD Environment Variables Template
# Copy to .env and populate with actual values
# NEVER commit .env to version control

# ============================================
# JFrog Artifactory Configuration
# ============================================
# PyPI repository credentials
JFROG_USER=your_username
JFROG_PASSWORD=your_password_or_token
JFROG_URL=https://hypersec.jfrog.io/artifactory/api/pypi/hypersec-pypi-local

# Pip configuration (for private package installation)
PIP_INDEX_URL=https://${JFROG_USER}:${JFROG_PASSWORD}@hypersec.jfrog.io/artifactory/api/pypi/hypersec-pypi-local/simple
PIP_EXTRA_INDEX_URL=https://pypi.org/simple

# Twine configuration (for package upload)
TWINE_REPOSITORY_URL=https://hypersec.jfrog.io/artifactory/api/pypi/hypersec-pypi-local
TWINE_USERNAME=${JFROG_USER}
TWINE_PASSWORD=${JFROG_PASSWORD}

# ============================================
# GitHub Configuration
# ============================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_ORG={{ github_org }}
GITHUB_REPO={{ project_name }}

# ============================================
# CI Environment
# ============================================
# Bootstrap configuration
BOOTSTRAP_INSTALL=0  # Set to 1 to enable tool installation
HSF_CI_VENV=.venv-ci
HSF_PREFERRED_PYTHON=3.11
HSF_MIN_PYTHON=3.11
HSF_IN_CI_VENV=0  # Set by hyperlib when running in .venv-ci

# Logging configuration
CI_LOG_FILE=ci.log
CI_LOG_STRUCTURED=0  # Set to 1 for JSON logging
NO_COLOR=0  # Set to 1 to disable color output

# ============================================
# Docker/Kubernetes Configuration
# ============================================
DOCKER_REGISTRY=hypersec.jfrog.io
DOCKER_NAMESPACE=hypersec-docker
K8S_NAMESPACE=hypersec
K8S_CONTEXT=production

# ============================================
# Application Configuration
# ============================================
{%- if project_type == 'application' %}
# FastAPI configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=0  # Set to 1 for development auto-reload
{%- endif %}

{%- if project_type == 'cli' %}
# CLI tool configuration
CLI_CONFIG_DIR=${HOME}/.config/{{ package_name }}
CLI_CACHE_DIR=${HOME}/.cache/{{ package_name }}
CLI_LOG_LEVEL=INFO
{%- endif %}

# ============================================
# Testing Configuration
# ============================================
PYTEST_ADDOPTS=--cov --cov-report=term-missing
PYTEST_CACHE_DIR=.pytest_cache

# ============================================
# Security/Secrets
# ============================================
# Add any application-specific secrets here
# DATABASE_URL=postgresql://user:pass@localhost/dbname
# REDIS_URL=redis://localhost:6379/0
# API_KEY=your_api_key_here

# ============================================
# Feature Flags
# ============================================
ENABLE_DEBUG=0
ENABLE_PROFILING=0
ENABLE_METRICS=1
