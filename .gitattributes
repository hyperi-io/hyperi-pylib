# Git Attributes - HyperCI Project
# Auto-generated by ci/modules/common/git.d/30-setup-gitattributes.py

# Line ending normalization
* text=auto

# Source files
*.py text eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files (Git LFS)
*.whl binary
*.egg binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary
*.bin binary
*.tar.gz binary
*.zip binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Diff settings
*.py diff=python
*.md diff=markdown


# === ci/common gitattributes patterns ===
# Common gitattributes for all project types
# Language-agnostic patterns

# Auto-detect text files and normalize line endings to LF

# Documents - treat as text
*.rst text
*.adoc text

# Configuration files - treat as text
*.toml text
*.ini text
*.cfg text
*.conf text
*.config text

# Shell scripts - LF line endings
*.bash text eol=lf

# Scripts - treat as text with LF
*.js text eol=lf
*.ts text eol=lf

# Images - binary, no diff
*.svg binary

# Fonts - binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Archives - binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.rar binary

# Certificates and keys - binary, no diff
*.pem binary
*.key binary
*.crt binary
*.cert binary
*.p12 binary
*.pfx binary

# Lock files - don't generate diffs (too noisy)
package-lock.json -diff
yarn.lock -diff
poetry.lock -diff
Pipfile.lock -diff
uv.lock -diff
Cargo.lock -diff

# Generated files - mark as generated
*.min.js linguist-generated=true
*.min.css linguist-generated=true
*-lock.json linguist-generated=true
# === End ci/common ===


