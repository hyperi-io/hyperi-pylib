# Git attributes for Python Package Template
# Enables Git LFS for large files while preserving sample data

# ============================================
# LINE ENDING NORMALIZATION
# ============================================

# Default behavior: auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Force LF for specific file types (cross-platform consistency)
*.py text eol=lf
*.pyi text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.fish text eol=lf
*.zsh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.json text eol=lf
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.sql text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.env.example text eol=lf
LICENSE text eol=lf
README text eol=lf
CHANGELOG text eol=lf
AUTHORS text eol=lf
CONTRIBUTORS text eol=lf
NOTICE text eol=lf
VERSION text eol=lf

# ============================================
# BINARY FILES
# ============================================

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.eps binary
*.webp binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.rar binary

# Executables
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Data files
*.pkl binary
*.pickle binary
*.npy binary
*.npz binary
*.h5 binary
*.hdf5 binary
*.parquet binary
*.arrow binary
*.feather binary
*.db binary
*.sqlite binary
*.sqlite3 binary

# Keep LFS rules minimal; do not track text/script files in LFS

# Track files >10MB with Git LFS (but only for specific types)
# Note: Above overrides ensure scripts and code files never use LFS

# Specific large file types always use LFS
*.log filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.whl filter=lfs diff=lfs merge=lfs -text

# Track large sample datasets
data/**/*.log filter=lfs diff=lfs merge=lfs -text
data/**/*.txt filter=lfs diff=lfs merge=lfs -text
data/**/*.csv filter=lfs diff=lfs merge=lfs -text
data/**/*.json filter=lfs diff=lfs merge=lfs -text
data/**/*.xml filter=lfs diff=lfs merge=lfs -text

# Track compressed files with LFS
*.log.gz filter=lfs diff=lfs merge=lfs -text
*.log.bz2 filter=lfs diff=lfs merge=lfs -text
*.log.xz filter=lfs diff=lfs merge=lfs -text
*.log.zip filter=lfs diff=lfs merge=lfs -text

# Track large test data
tests/data/**/*.log filter=lfs diff=lfs merge=lfs -text
tests/fixtures/**/*.log filter=lfs diff=lfs merge=lfs -text

# Track large output files
output/**/*.log filter=lfs diff=lfs merge=lfs -text
output/**/*.json filter=lfs diff=lfs merge=lfs -text
output/**/*.csv filter=lfs diff=lfs merge=lfs -text

# Track ML models and large binaries
*.model filter=lfs diff=lfs merge=lfs -text
*.weights filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.hdf5 filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text

# Track large documentation assets
docs/**/*.pdf filter=lfs diff=lfs merge=lfs -text
docs/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
docs/**/*.mov filter=lfs diff=lfs merge=lfs -text
docs/**/*.avi filter=lfs diff=lfs merge=lfs -text

# ============================================
# DIFF SETTINGS
# ============================================

# Use Python diff for Python files
*.py diff=python
*.pyi diff=python

# Use appropriate diff for config files
*.toml diff=toml
*.yaml diff=yaml
*.yml diff=yaml
*.json diff=json

# ============================================
# MERGE DRIVERS
# ============================================

# Prevent merge conflicts in generated files
CHANGELOG.md merge=ours
VERSION merge=ours
package-lock.json merge=ours
poetry.lock merge=ours
Pipfile.lock merge=ours

# ============================================
# EXPORT IGNORE
# ============================================

# Files to exclude from archive exports
.github export-ignore
.gitignore export-ignore
.gitattributes export-ignore
.editorconfig export-ignore
.pre-commit-config.yaml export-ignore
.travis.yml export-ignore
.gitlab-ci.yml export-ignore
.circleci export-ignore
tests/ export-ignore
docs/ export-ignore
examples/ export-ignore
scripts/dev/ export-ignore
*.md export-ignore
.env export-ignore
.env.* export-ignore
node_modules/ export-ignore

# ============================================
# LANGUAGE STATISTICS
# ============================================

# Linguist overrides for accurate language detection
*.log linguist-detectable=false
data/* linguist-documentation
docs/* linguist-documentation
tests/fixtures/* linguist-generated
tests/data/* linguist-generated
output/* linguist-generated

# Project-specific configuration (not in ci/ subtree)
# ci.yaml is at project root, separate from hyperci subtree
ci.yaml merge=ours
