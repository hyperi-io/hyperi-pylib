      "WebFetch",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob",
      "Grep",
      "LS",
      "Search",
      "Find",
      "Read(~/.gitconfig)",
      "Bash(.tmp/*)",
      "Bash(mkdir .tmp *)",
      "Bash(rm .tmp/*)",
      "Bash(rm -rf .tmp/*)",
      "Bash(chmod +x .tmp/*)",
      "Bash(sh .tmp/*)",
      "Bash(bash .tmp/*)",
      "Bash(python .tmp/*)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(fd *)",
      "Bash(rg *)",
      "Bash(parallel *)",
      "Bash(bat *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(tar *)",
      "Bash(gzip *)",
      "Bash(gunzip *)",
      "Bash(bzip2 *)",
      "Bash(bunzip2 *)",
      "Bash(xz *)",
      "Bash(unxz *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kubectl *)",
      "Bash(git *)",
      "Bash(jf *)",
      "Bash(gh *)",
      "Bash(cd *)",
      "Bash(export *)",
      "Bash(source *)",
      "Bash(date *)",
      "Bash(./ci/bootstrap *)",
      "Bash(./ci/run *)",
      "Bash(./ci/ai *)",
      "Bash(./ci/gitci *)",
      "Bash(ci/bootstrap *)",
      "Bash(ci/run *)",
      "Bash(ci/ai *)",
      "Bash(ci/gitci *)",
      "Bash(uv *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(python -m *)",
      "Bash(pip *)",
      "Bash(ruff *)",
      "Bash(black *)",
      "Bash(mypy *)",
      "Bash(coverage *)",
      "Bash(tox *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(make *)",
      "Bash(cmake *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(diff *)",
      "Bash(patch *)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(ps *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(xargs *)",
      "Bash([A-Z_]*=* *)",
      "Bash(export [A-Z_]*)"
    ],
    "deny": [],
    "ask": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(:|:*)",
      "Bash(curl * | sh *)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh *)",
      "Bash(wget * | bash *)",
      "Write(ci/**)",
      "Edit(ci/**)",
      "Bash(* && *)",
      "Bash(* || *)",
      "Bash(* ; *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(mv *)",
      "Bash(kill *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"Today: $(date +%Y-%m-%d)\"; echo \"\"; echo \"=== CONTEXT DETECTION ===\"; if [ -f ci.yaml ] && [ -f STATE.md ]; then echo \"Context: PROJECT (has ci.yaml)\"; echo \"\"; cat STATE.md; elif [ -f ci/STATE.md ] && [ ! -f ci.yaml ]; then echo \"Context: HYPERCI REPOSITORY (ci infrastructure)\"; echo \"\"; cat ci/STATE.md; elif [ -f STATE.md ]; then cat STATE.md; elif [ -f CLAUDE.md ]; then cat CLAUDE.md; fi; echo \"\"; if [ -f TODO.md ]; then cat TODO.md; fi; echo \"\"; echo \"=== STANDARDS (ALWAYS APPLY) ===\"; echo \"CRITICAL: NEVER add Co-Authored-By or AI attribution to commits.\"; echo \"Git pre-commit hook will automatically strip attribution.\"; echo \"\"; if [ -d ci/docs/standards ]; then find ci/docs/standards -name \"*.md\" -type f -exec sh -c \"echo \\\"--- {} ---\\\" && cat {}\" \\;; elif [ -d docs/standards ]; then find docs/standards -name \"*.md\" -type f -exec sh -c \"echo \\\"--- {} ---\\\" && cat {}\" \\;; fi'"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "12288",
    "USE_BUILTIN_RIPGREP": "1",
    "CLAUDE_CODE_ENABLE_PARALLEL_TOOLS": "1",
    "CLAUDE_CODE_MAX_PARALLEL_TOOLS": "3",
    "CLAUDE_CODE_CONTEXT_WINDOW_TOKENS": "950000"
  }
}
