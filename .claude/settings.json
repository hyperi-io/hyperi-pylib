{
  "env": {
    "ANTHROPIC_MODEL": "opusplan",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-1-20250805",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-5-20250929",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-opus-4-1-20250805",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "16384",
    "MAX_THINKING_TOKENS": "16000",
    "CLAUDE_CODE_CONTEXT_WINDOW_TOKENS": "200000",
    "CLAUDE_CODE_AGGRESSIVE_CONTEXT_MANAGEMENT": "0",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "USE_BUILTIN_RIPGREP": "1",
    "DISABLE_COST_WARNINGS": "1",
    "CLAUDE_CODE_ENABLE_PARALLEL_TOOLS": "1",
    "CLAUDE_CODE_MAX_PARALLEL_TOOLS": "3",
    "BASH_MAX_OUTPUT_LENGTH": "50000",
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "BASH_MAX_TIMEOUT_MS": "120000",
    "MAX_MCP_OUTPUT_TOKENS": "25000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "enabledPlugins": {
    "docker": true
  },
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-knowledge-graph",
        "--memory-path",
        "/projects/hyperlib/.claude/claude-memory"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(.venv-ci/*)",
      "Bash(.venv/*)",
      "Bash(ci-local/.venv/*)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(poetry *)",
      "Bash(pytest *)",
      "Bash(black *)",
      "Bash(flake8 *)",
      "Bash(mypy *)",
      "Bash(ruff *)",
      "Bash(isort *)",
      "Bash(coverage *)",
      "Bash(tox *)"
    ],
    "deny": [],
    "ask": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(:|:*)",
      "Bash(curl * | sh *)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh *)",
      "Bash(wget * | bash *)",
      "Write(ci/**)",
      "Edit(ci/**)",
      "Bash(* && *)",
      "Bash(* || *)",
      "Bash(* ; *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(mv *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"Today: $(date +%Y-%m-%d)\"; echo \"\"; if [ -f STATE.md ]; then cat STATE.md; elif [ -f CLAUDE.md ]; then cat CLAUDE.md; fi; echo \"\"; if [ -f TODO.md ]; then cat TODO.md; fi; echo \"\"; if [ -d docs/standards ]; then for std in docs/standards/*.md; do [ -f \"$std\" ] && cat \"$std\" && echo \"\"; done; fi'"
          }
        ]
      }
    ]
  }
}
