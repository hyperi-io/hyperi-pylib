apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ package_name }}-config
  namespace: {{ package_name }}
data:
  ENVIRONMENT: "production"
  LOG_LEVEL: "INFO"
  {%- if project_type == 'application' %}
  API_WORKERS: "4"
  API_HOST: "0.0.0.0"
  API_PORT: "8000"
  {%- endif %}
  {%- if project_type == 'cli' %}
  CLI_LOG_LEVEL: "INFO"
  {%- endif %}
---
apiVersion: v1
kind: Secret
metadata:
  name: {{ package_name }}-secrets
  namespace: {{ package_name }}
type: Opaque
stringData:
  # JFrog Artifactory credentials
  JFROG_USER: "changeme"
  JFROG_PASSWORD: "changeme"
  # Application secrets
  DATABASE_URL: "postgresql://user:pass@postgres:5432/{{ package_name }}"
  REDIS_URL: "redis://redis:6379/0"
  API_KEY: "changeme"
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ package_name }}
  namespace: {{ package_name }}
---
apiVersion: v1
kind: Namespace
metadata:
  name: {{ package_name }}
