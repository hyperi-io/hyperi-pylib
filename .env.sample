# Hyperlib Environment Configuration
# ===================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env (it's in .gitignore)

# ============================================================================
# CI/Build Configuration
# ============================================================================

# All CI/build configuration is in: ci-local/.env.sample
#
# To configure CI credentials and build settings:
#   1. Run: ./ci/bootstrap --install
#   2. Edit: ci-local/.env (created from ci-local/.env.sample)
#   3. See: ci-local/.env.sample for all available CI options
#
# CI credentials in ci-local/.env:
#   - ARTIFACTORY_USERNAME / ARTIFACTORY_PASSWORD (required)
#   - DOCKER_USERNAME / DOCKER_PASSWORD (optional, prevents throttling)
#   - CI_LOG_LEVEL, BUILD_PROFILE, etc.

# This file (.env) is for application runtime configuration only.

# ============================================================================
# Application Configuration (Hyperlib Runtime)
# ============================================================================

# Database Configuration (if using hyperlib.dbconn)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=myapp
# DB_USER=myuser
# DB_PASSWORD=mypassword

# API Configuration (if using hyperlib.application.api)
# API_HOST=0.0.0.0
# API_PORT=8000
# API_DEBUG=false

# Logging Configuration (if using hyperlib.logger)
# LOG_LEVEL=INFO
# LOG_FORMAT=json  # or 'text'

# Prometheus Metrics (if using hyperlib.prometheus)
# METRICS_PORT=9090
# METRICS_ENABLED=true

# ============================================================================
# Testing Configuration
# ============================================================================

# Coverage Override (rarely needed)
# CI_COVERAGE_SOURCE=src/hyperlib

# Skip Slow Tests (speeds up development)
# PYTEST_SKIP_SLOW=1

# ============================================================================
# Build/Release Configuration
# ============================================================================

# NOTE: Most build/release config is in ci-local/.env
# See ci-local/.env.sample for: FORCE_RELEASE, CI_PUSH, CI_LOG_LEVEL, etc.

# ============================================================================
# Quick Start
# ============================================================================
#
# 1. Bootstrap CI environment:
#    ./ci/bootstrap --install
#
# 2. Edit ci-local/.env with JFrog credentials
#
# 3. Run checks:
#    ./ci/run check
#
# 4. Build package:
#    ./ci/run build
#
# 5. Create release:
#    FORCE_RELEASE=1 ./ci/run release
#
# 6. Create and push release:
#    FORCE_RELEASE=1 CI_PUSH=1 ./ci/run release
#
# ============================================================================
# Documentation
# ============================================================================
#
# - STATE.md: Project overview and AI assistant guidance
# - README.md: User-facing documentation
# - TODO.md: Current tasks and priorities
# - ci-local/.env.sample: CI credential templates
# - ci/docs/: Complete CI documentation
#
