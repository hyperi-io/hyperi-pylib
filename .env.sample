# Hyperlib Application Configuration
# ====================================
# This file is for APPLICATION RUNTIME configuration only.
#
# For CI/build configuration, see: ci-local/.env.sample
#
# Copy this file to .env and add your application-specific values.
# IMPORTANT: Never commit .env (it's in .gitignore)

# ============================================================================
# Application Configuration
# ============================================================================

# Database Configuration (if using hyperlib.dbconn)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=myapp
# DB_USER=myuser
# DB_PASSWORD=mypassword

# API Configuration (if using hyperlib.application.api)
# API_HOST=0.0.0.0
# API_PORT=8000
# API_DEBUG=false

# Logging Configuration (if using hyperlib.logger)
# LOG_LEVEL=INFO
# LOG_FORMAT=json  # or 'text'

# Prometheus Metrics (if using hyperlib.prometheus)
# METRICS_PORT=9090
# METRICS_ENABLED=true

# ============================================================================
# Testing Configuration
# ============================================================================

# Container Registry Authentication (for container/Helm integration tests)
# Prevents rate limiting and enables cached/private image pulls
#
# Precedence (first available wins):
# 1. Docker Hub (explicit override) > 2. Artifactory (cached default) > 3. Direct
#
# Option 1: Docker Hub Direct (OVERRIDE - only set if you specifically need Docker Hub)
# Use case: Testing Docker-specific features, debugging registry issues
# Unauthenticated: 100 pulls/6hr, Authenticated: 200 pulls/6hr
# DOCKER_USERNAME=your-dockerhub-username
# DOCKER_PASSWORD=your-dockerhub-password-or-token
#
# Option 2: Artifactory Container Cache (RECOMMENDED - automatic if Docker not set)
# Uses JFrog as caching proxy for Docker Hub, GHCR, Quay, GCR
# Virtual repo 'hypersec-docker' aggregates all container registries
# Cached pulls = faster + no rate limiting + works offline
ARTIFACTORY_CONTAINER_URL=hypersec.jfrog.io/hypersec-docker
# ARTIFACTORY_USERNAME=your-email@hypersec.io  # Reuses from root .env if already set
# ARTIFACTORY_PASSWORD=your-jfrog-password     # Reuses from root .env if already set
