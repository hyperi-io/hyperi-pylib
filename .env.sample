# Hyperlib Application Configuration
# ====================================
# This file is for APPLICATION RUNTIME configuration only.
#
# For CI/build configuration, see: ci-local/.env.sample
#
# Copy this file to .env and add your application-specific values.
# IMPORTANT: Never commit .env (it's in .gitignore)

# ============================================================================
# Application Configuration
# ============================================================================

# Database Configuration (if using hyperlib.dbconn)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=myapp
# DB_USER=myuser
# DB_PASSWORD=mypassword

# API Configuration (if using hyperlib.application.api)
# API_HOST=0.0.0.0
# API_PORT=8000
# API_DEBUG=false

# Logging Configuration (if using hyperlib.logger)
# LOG_LEVEL=INFO
# LOG_FORMAT=json  # or 'text'

# Prometheus Metrics (if using hyperlib.prometheus)
# METRICS_PORT=9090
# METRICS_ENABLED=true

# ============================================================================
# Testing Configuration
# ============================================================================

# Docker Hub Authentication (for container/Helm integration tests)
# Prevents rate limiting during test runs
# Unauthenticated: 100 pulls/6hr, Authenticated: 200 pulls/6hr
# DOCKER_USERNAME=your-dockerhub-username
# DOCKER_PASSWORD=your-dockerhub-password-or-token
