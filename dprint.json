{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "projectType": "openSource",
  "lineWidth": 100,
  "indentWidth": 2,
  "useTabs": false,
  "newLineKind": "lf",
  "markdown": {
    "lineWidth": 100,
    "textWrap": "maintain"
  },
  "toml": {
    "lineWidth": 100
  },
  "json": {
    "lineWidth": 100,
    "indentWidth": 2
  },
  "excludes": [
    "**/node_modules",
    "**/.venv",
    "**/target",
    "**/dist",
    "**/build",
    "**/vendor",
    "**/.git",
    "**/CHANGELOG.md",
    "**/*.lock",
    "**/package-lock.json",
    "**/pnpm-lock.yaml",
    "**/ci/**",
    "**/ai/**"
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.17.8.wasm",
    "https://plugins.dprint.dev/toml-0.6.3.wasm",
    "https://plugins.dprint.dev/json-0.19.4.wasm"
  ]
}
