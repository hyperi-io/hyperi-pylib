#!/bin/bash
# Pre-commit hook: Version Pre-sync Strategy
#
# This hook runs BEFORE commits are created to ensure VERSION file
# is synced with the next semantic-release version.
#
# Part of dual pre-sync strategy:
# - Option 1: Pre-commit hook (this file) - local development
# - Option 2: CI pre-release sync (ci-local/python/ci.d/89-pre-release-sync.py)
#
# When to run:
# - Only on main/master branches (release branches)
# - Only when semantic-release would create a new version
# - Skips if CI_SKIP_VERSION_SYNC=1 (for testing)

set -e

# Skip if disabled
if [ "$CI_SKIP_VERSION_SYNC" = "1" ]; then
    exit 0
fi

# Get current branch
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

# Only run on release branches
if [[ "$BRANCH" != "main" && "$BRANCH" != "master" ]]; then
    exit 0
fi

# Check if ci-local/.venv exists (needed for semantic-release)
if [ ! -d "ci-local/.venv" ]; then
    echo "WARNING: ci-local/.venv not found, skipping version pre-sync"
    echo "Run: ./ci/bootstrap --install"
    exit 0
fi

# Check if semantic-release is available
if ! ci-local/.venv/bin/python -m semantic_release --version >/dev/null 2>&1; then
    echo "WARNING: semantic-release not available, skipping version pre-sync"
    exit 0
fi

# Get next version from semantic-release (dry-run)
echo "Pre-commit: Checking if version should be updated..."
NEXT_VERSION=$(ci-local/.venv/bin/python -m semantic_release version --print 2>/dev/null || echo "")

# If no new version, skip
if [ -z "$NEXT_VERSION" ]; then
    exit 0
fi

# Check if this looks like a valid version
if [[ ! "$NEXT_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+ ]]; then
    echo "WARNING: Invalid version from semantic-release: $NEXT_VERSION"
    exit 0
fi

echo "Pre-commit: Next version will be: $NEXT_VERSION"

# Update VERSION file
echo "$NEXT_VERSION" > VERSION

# Stage VERSION file
git add VERSION

echo "Pre-commit: ✓ VERSION pre-synced to $NEXT_VERSION"

exit 0
