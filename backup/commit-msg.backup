#!/usr/bin/env bash
#  Project:      hyperci
#  File:         commit-msg
#  Purpose:      Git commit-msg hook - remove AI attribution automatically
#  Language:     Bash
#
#  Description:
#      Commit-msg hook to AUTOMATICALLY REMOVE AI attribution from commits.
#      This enforces the "no AI attribution" policy for all HyperSec projects.
#
#  Behavior:
#      - Removes AI attribution patterns from commit message
#      - Warns user that attribution was removed
#      - Uses local git user.name and user.email as author
#      - Allows commit to proceed with cleaned message
#
#  Attribution patterns removed (verified Oct 2025):
#      - (Anthropic)
#      - OpenAI ChatGPT / GPT-3.5 / GPT-4 / o1-mini
#      - GitHub Copilot
#      - Amazon CodeWhisperer
#      - Tabnine
#      - Cursor
#      - Google Gemini / Duet AI
#      - Codeium / Windsurf
#
#  Installation:
#      Installed automatically by ci/gitci setup hooks

set -o errexit
set -o nounset
set -o pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# --- AI attribution regex patterns (confirmed + preventive) ---
AI_ATTRIBUTION_PATTERNS=(
    # === (Anthropic) ===
    "^🤖 Generated with \\[\\].*"
    "🤖 Generated with \\[\\].*"
    " <.*@anthropic\\.com>.*"
    "Co-authored-by:<.*@anthropic\\.com>.*"
    "Generated[- ]by:.*.*"
    "AI[- ]Assisted[- ]by:.*.*"

    # === ChatGPT / GPT-4 / OpenAI Codex ===
    "Co-Authored-By:.*ChatGPT.*"
    "Co-authored-by:.*ChatGPT.*"
    "Co-Authored-By:.*GPT-?([34]|4\\.5|o1).*"
    "Co-authored-by:.*GPT-?([34]|4\\.5|o1).*"
    "Generated[- ]by:.*ChatGPT.*"
    "Generated[- ]by:.*GPT.*"
    "AI[- ]Assisted[- ]by:.*ChatGPT.*"
    "AI[- ]Assisted[- ]by:.*GPT.*"
    "\\(codex\\).*"
    "Co-Authored-By:.*[Cc]odex.*"
    "Co-authored-by:.*[Cc]odex.*"

    # === GitHub Copilot ===
    "Co-Authored-By: GitHub Copilot <.*>"
    "Co-authored-by: GitHub Copilot <.*>"
    "Co-Authored-By:.*Copilot.*"
    "Co-authored-by:.*Copilot.*"
    "Generated[- ]by:.*Copilot.*"

    # === Amazon CodeWhisperer ===
    "Co-Authored-By:.*CodeWhisperer.*"
    "Co-authored-by:.*CodeWhisperer.*"
    "Generated[- ]by:.*CodeWhisperer.*"

    # === Tabnine ===
    "Co-Authored-By:.*Tabnine.*"
    "Co-authored-by:.*Tabnine.*"
    "Generated[- ]by:.*Tabnine.*"

    # === Cursor ===
    "Co-Authored-By: Cursor <.*>"
    "Co-authored-by: Cursor <.*>"
    "Generated[- ]by:.*Cursor.*"

    # === Google Gemini / Duet AI ===
    "Co-Authored-By:.*[Gg]emini.*"
    "Co-authored-by:.*[Gg]emini.*"
    "Co-Authored-By:.*[Dd]uet.*"
    "Co-authored-by:.*[Dd]uet.*"
    "Generated[- ]by:.*Gemini.*"
    "Generated[- ]by:.*Duet.*"

    # === Codeium / Windsurf ===
    "Co-Authored-By:.*[Cc]odeium.*"
    "Co-authored-by:.*[Cc]odeium.*"
    "Co-Authored-By:.*[Ww]indsurf.*"
    "Co-authored-by:.*[Ww]indsurf.*"
    "Generated[- ]by:.*Codeium.*"
    "Generated[- ]by:.*Windsurf.*"
)

# --- Detect any matching pattern ---
FOUND_ATTRIBUTION=false
for pattern in "${AI_ATTRIBUTION_PATTERNS[@]}"; do
    if echo "$COMMIT_MSG" | grep -qE "$pattern"; then
        FOUND_ATTRIBUTION=true
        break
    fi
done

if [ "$FOUND_ATTRIBUTION" = false ]; then
    exit 0
fi

echo "⚠️  WARNING: AI attribution detected and removed from commit message"
echo

# --- Strip offending lines completely ---
CLEANED_MSG="$COMMIT_MSG"
for pattern in "${AI_ATTRIBUTION_PATTERNS[@]}"; do
    CLEANED_MSG=$(echo "$CLEANED_MSG" | grep -vE "$pattern" || echo "$CLEANED_MSG")
done

# --- Remove trailing blank lines ---
CLEANED_MSG=$(echo "$CLEANED_MSG" | sed -e :a -e '/^[[:space:]]*$/d;N;ba')

# --- Rewrite the commit message file ---
printf '%s\n' "$CLEANED_MSG" > "$COMMIT_MSG_FILE"

# --- Display author confirmation ---
GIT_USER_NAME=$(git config user.name 2>/dev/null || echo "HyperSec Team")
GIT_USER_EMAIL=$(git config user.email 2>/dev/null || echo "noreply@hypersec.io")

cat <<EOF

AI attribution lines have been removed.
Commit will be attributed to: $GIT_USER_NAME <$GIT_USER_EMAIL>

HyperSec Policy: Commits represent HUMAN decisions and accountability.
AI tools are development assistants, not co-authors.

Rationale:
  - We don't attribute commits to compilers, IDEs, or linters.
  - AI coding assistants are tools, not team members.
  - Contributor lists must reflect human contributors only.

EOF

exit 0
