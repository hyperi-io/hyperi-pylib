# CI Tool Dependencies Template
# This template is copied to ci-local/pyproject.toml during bootstrap
# It defines CI tool dependencies installed in ci-local/.venv (NOT project .venv)
# Each project can customize their copy in ci-local/pyproject.toml

[project]
name = "hyperlib-ci"
version = "1.0.0"
description = "CI tools for hyperlib"
requires-python = ">=3.11"  # CI tools require Python 3.11+

# CI tool dependencies (installed in ci/.venv)
dependencies = [
    "setuptools>=70.0.0",
    "wheel>=0.42.0",
    "build>=1.0.0",
    "pyyaml>=6.0",      # MUST BE FIRST - required for ci/ci.yaml config
    "loguru>=0.7.0",    # RFC3339 logging
    "dynaconf>=3.2.0",  # Configuration management (required by ci_lib.py)
    "mergedeep>=1.3.4", # Deep merge for JSON/dict (replaces custom deep_merge_json)
    # Testing
    "pytest>=8.0.0",
    "pytest-cov>=4.0.0",  # Coverage reporting
    # Code Quality
    "ruff>=0.1.0",      # Linting (fast, modern)
    "black>=24.0.0",    # Code formatting
    "isort>=5.12.0",    # Import sorting
    "pyright>=1.1.0",   # Type checking (faster than mypy)
    # Security
    "bandit[toml]>=1.7.0",  # Security linting
    "pip-audit>=2.6.0",     # Dependency vulnerability scanning
    # Documentation
    "interrogate>=1.5.0",   # Docstring coverage
    # Code Analysis
    "vulture>=2.7.0",   # Dead code detection
    "vermin>=1.6.0",    # Python version compatibility
    # Publishing
    "twine>=5.0.0",     # Package publishing to JFrog
    # Versioning
    "python-semantic-release>=9.0.0",
    # Nuitka Support
    "pycryptodomex>=3.20.0",  # Required for Nuitka traceback-encryption plugin
]

# Nuitka is NOT in dependencies - installed separately by 25-nuitka.py
# This allows JFrog enforcement (nuitka-commercial vs nuitka OSS) and smart detection

# ============================================================================
# Package Index Configuration (uv)
# ============================================================================
# Force Nuitka to ONLY use JFrog Artifactory (no fallback to public PyPI)
# JFrog has Nuitka Commercial 2.7.16, public PyPI has OSS 2.8.1
#
# NOTE: uv index URLs require credentials to be set via environment variables:
#   UV_INDEX_<NAME>_USERNAME and UV_INDEX_<NAME>_PASSWORD
#   OR use keyring for credential storage
#
# For now, we cannot use tool.uv.sources reliably because:
# 1. URL authentication is complex with uv
# 2. JFrog credentials need to be injected at runtime
#
# Instead, bootstrap will use uv pip install with explicit --index-url flag

# [[tool.uv.index]]
# name = "jfrog"
# url = "https://hypersec.jfrog.io/artifactory/api/pypi/hypersec-pypi-local/simple"
# explicit = true
#
# [tool.uv.sources]
# nuitka = { index = "jfrog" }
