#!/usr/bin/env python3
"""
Core CI entrypoint - Simple .d directory runner.

This script runs all scripts in ci.d/ directories in sorted order.
It ensures bootstrap has run first (to install hyperlib and tools).

Usage:
- ./scripts/ci              # Run all CI checks
- ./scripts/ci check        # Same as above
- ./scripts/ci --help       # Show help

CI Directory Discovery:
1. Core ci.d/: subtrees/hypersec-forge-core/scripts/ci.d/
2. Project ci.d/: scripts/ci.d/ (or HSF_CI_D env var)
3. Language ci.d/: Can be added via subtrees

All scripts are run in sorted order with "check" action.
"""

import argparse
import os
import subprocess
import sys
from pathlib import Path

# Get project root
THIS_DIR = Path(__file__).resolve().parent
if "hypersec-forge-core" in str(THIS_DIR):
    # Running from core subtree
    PROJECT_ROOT = THIS_DIR.parent.parent.parent
else:
    # Running from project root
    PROJECT_ROOT = THIS_DIR.parent


def find_ci_directories() -> list:
    """Find all ci.d directories to process."""
    ci_dirs = []

    # Core ci.d (always present)
    core_ci_d = THIS_DIR / "ci.d"
    if core_ci_d.exists():
        ci_dirs.append(("core", core_ci_d))

    # Project ci.d (from env or default location)
    if os.environ.get("HSF_CI_D"):
        project_ci_d = Path(os.environ["HSF_CI_D"])
        if project_ci_d.exists():
            ci_dirs.append(("project", project_ci_d))
    else:
        project_ci_d = PROJECT_ROOT / "scripts" / "ci.d"
        if project_ci_d.exists() and project_ci_d != core_ci_d:
            ci_dirs.append(("project", project_ci_d))

    return ci_dirs


def find_scripts(ci_dir: Path) -> list:
    """Find all executable scripts in a ci.d directory."""
    if not ci_dir.exists():
        return []

    scripts = []
    for item in sorted(ci_dir.iterdir()):
        # Skip non-files
        if not item.is_file():
            continue

        # Skip editor backups and config files
        if item.suffix in [".swp", ".bak", "~", ".yaml", ".yml", ".json", ".toml", ".md"]:
            continue

        # Only include .py, .sh, or executable files
        if not (item.suffix in [".py", ".sh"] or os.access(item, os.X_OK)):
            continue

        scripts.append(item)

    return scripts


def handle_clean_action(args) -> int:
    """Handle the clean action - remove build artifacts."""
    print("\nCleaning build artifacts...")

    patterns = [
        "dist/",
        "build/",
        "*.egg-info",
        "__pycache__/",
        ".pytest_cache/",
        ".mypy_cache/",
        ".ruff_cache/",
        "*.pyc",
        "*.pyo",
        ".coverage",
        "htmlcov/",
    ]

    import shutil
    import glob

    removed = []
    for pattern in patterns:
        if "/" in pattern:
            # Directory pattern
            dir_path = PROJECT_ROOT / pattern.rstrip("/")
            if dir_path.exists():
                if args.dry_run:
                    print(f"Would remove: {dir_path}")
                else:
                    shutil.rmtree(dir_path)
                    removed.append(str(dir_path))
                    print(f"Removed: {dir_path}")
        else:
            # File pattern
            for item in PROJECT_ROOT.rglob(pattern):
                if args.dry_run:
                    print(f"Would remove: {item}")
                else:
                    if item.is_dir():
                        shutil.rmtree(item)
                    else:
                        item.unlink()
                    removed.append(str(item))

    if removed and not args.dry_run:
        print(f"\n✓ Cleaned {len(removed)} items")
    elif args.dry_run:
        print("\n✓ Dry run complete")
    else:
        print("\n✓ No artifacts to clean")

    return 0


def run_script(script: Path, action: str = "check") -> int:
    """Run a single CI script."""
    print(f"\n{'='*60}")
    print(f"Running: {script.name}")
    print(f"{'='*60}")

    # Use .venv-ci Python if available (required for hyperlib imports)
    venv_python = PROJECT_ROOT / ".venv-ci" / "bin" / "python"
    if not venv_python.exists():
        venv_python = Path(sys.executable)

    # Determine how to run the script
    if script.suffix == ".py":
        cmd = [str(venv_python), str(script), action]
    elif script.suffix == ".sh":
        cmd = ["bash", str(script), action]
    else:
        cmd = [str(script), action]

    result = subprocess.run(cmd, cwd=PROJECT_ROOT)
    return result.returncode


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="CI runner for HyperSec projects",
        epilog="""
Examples:
  ./scripts/ci check       # Run all checks (lint, test, type-check)
  ./scripts/ci build       # Build package
  ./scripts/ci deploy      # Build and publish to JFrog
  ./scripts/ci release     # Full release (version, build, deploy)
  ./scripts/ci clean       # Remove build artifacts
        """
    )
    parser.add_argument(
        "action",
        nargs="?",
        default="check",
        choices=["check", "install", "lint", "test", "build", "deploy", "release", "clean", "all"],
        help="Action to perform (default: check)"
    )
    parser.add_argument(
        "--continue-on-error",
        action="store_true",
        help="Continue running even if a script fails"
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Force action (e.g., force release without CI check)"
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would happen without doing it"
    )
    args = parser.parse_args()

    print("="*60)
    print("HyperSec CI")
    print("="*60)

    # Handle special actions first
    if args.action == "clean":
        return handle_clean_action(args)

    # Ensure bootstrap has run (except for clean which doesn't need it)
    bootstrap_script = PROJECT_ROOT / "scripts" / "bootstrap"
    if bootstrap_script.exists():
        print("\n[Ensuring bootstrap has run...]")
        result = subprocess.run(
            [sys.executable, str(bootstrap_script)],
            cwd=PROJECT_ROOT
        )
        if result.returncode != 0:
            print("\nERROR: Bootstrap failed. Run: ./scripts/bootstrap --install")
            return 1
    else:
        print("\nWARNING: No bootstrap script found, skipping bootstrap check")

    # Set environment variables for flags
    if args.force:
        os.environ["FORCE_RELEASE"] = "1"
        os.environ["CI_FORCE"] = "1"
    if args.dry_run:
        os.environ["DRY_RUN"] = "1"
        os.environ["CI_DRY_RUN"] = "1"

    # Find all ci.d directories
    ci_dirs = find_ci_directories()
    if not ci_dirs:
        print("\nNo ci.d directories found")
        return 0

    print(f"\nCI directories:")
    for label, ci_dir in ci_dirs:
        print(f"  - {label}: {ci_dir}")

    # Run all scripts in order
    failed_scripts = []
    for label, ci_dir in ci_dirs:
        scripts = find_scripts(ci_dir)
        if not scripts:
            continue

        print(f"\n{'='*60}")
        print(f"{label.upper()} CI Scripts")
        print(f"{'='*60}")

        for script in scripts:
            returncode = run_script(script, args.action)
            if returncode != 0:
                failed_scripts.append((label, script.name, returncode))
                if not args.continue_on_error:
                    print(f"\nERROR: {script.name} failed with code {returncode}")
                    return returncode

    # Summary
    print(f"\n{'='*60}")
    print("CI Summary")
    print(f"{'='*60}")

    if failed_scripts:
        print(f"\n{len(failed_scripts)} script(s) failed:")
        for label, name, code in failed_scripts:
            print(f"  - [{label}] {name} (exit code: {code})")
        return 1
    else:
        print("\n✓ All CI checks passed")
        return 0


if __name__ == "__main__":
    sys.exit(main())