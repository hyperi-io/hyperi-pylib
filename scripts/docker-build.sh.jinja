#!/usr/bin/env bash
# Build Docker image with correct Python version from pyproject.toml

set -euo pipefail

# Extract Python version from pyproject.toml
PYTHON_VERSION=$(python -c "
import tomllib
with open('pyproject.toml', 'rb') as f:
    data = tomllib.load(f)
    requires = data.get('project', {}).get('requires-python', '>=3.11')
    # Extract major.minor version from requires-python
    import re
    match = re.search(r'(\d+\.\d+)', requires)
    if match:
        print(match.group(1))
    else:
        print('3.11')  # fallback
" 2>/dev/null || echo "3.11")

echo "Building Docker image with Python ${PYTHON_VERSION}"

# Get version from VERSION file
VERSION=$(cat VERSION)
DOCKER_IMAGE="hypersec.jfrog.io/hypersec-docker/{{ package_name }}"

# Build with the extracted Python version
docker build \
    --build-arg PYTHON_VERSION="${PYTHON_VERSION}" \
    -t "${DOCKER_IMAGE}:${VERSION}" \
    -t "${DOCKER_IMAGE}:latest" \
    -t "{{ package_name }}:latest" \
    .

echo "Successfully built {{ package_name }} with Python ${PYTHON_VERSION}"
echo "Tagged as:"
echo "  - ${DOCKER_IMAGE}:${VERSION}"
echo "  - ${DOCKER_IMAGE}:latest"
echo "  - {{ package_name }}:latest"
