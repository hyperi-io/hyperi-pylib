version: '3.8'

services:
  {{ package_name }}:
    build:
      context: .
      dockerfile: Dockerfile
    image: {{ package_name }}:latest
    container_name: {{ package_name }}
    environment:
      - ENVIRONMENT=development
      {%- if project_type == 'application' %}
      - API_HOST=0.0.0.0
      - API_PORT=8000
      - API_RELOAD=1
      {%- endif %}
    env_file:
      - .env
    {%- if project_type == 'application' %}
    ports:
      - "8000:8000"
    {%- endif %}
    volumes:
      - ./src:/app/src:ro
      - ./tests:/app/tests:ro
      {%- if project_type == 'application' %}
      - ./logs:/app/logs
      {%- endif %}
    {%- if project_type == 'application' %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    {%- endif %}
    restart: unless-stopped

{%- if project_type == 'application' %}
  # Optional: Add Redis for caching
  redis:
    image: redis:7-alpine
    container_name: {{ package_name }}-redis
    ports:
      - "6379:6379"
    volumes:
      - redis-data:/data
    restart: unless-stopped

  # Optional: Add PostgreSQL for database
  postgres:
    image: postgres:15-alpine
    container_name: {{ package_name }}-postgres
    environment:
      - POSTGRES_USER=appuser
      - POSTGRES_PASSWORD=changeme
      - POSTGRES_DB={{ package_name }}
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    restart: unless-stopped

volumes:
  redis-data:
  postgres-data:
{%- endif %}
