# Copy this file to .env and customise for local development
# .env files are gitignored and should contain local secrets

# Database credentials (never commit real values)
DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_USER="myapp"
DATABASE_PASSWORD="secret"

# API configuration
API_PORT="8000"

# Logging
LOG_LEVEL="DEBUG"
