# Makefile for {{ project_name }}

.PHONY: help install dev test lint format type-check ci docker k8s clean

# Variables
PACKAGE_NAME := {{ package_name }}
DOCKER_IMAGE := hypersec.jfrog.io/hypersec-docker/$(PACKAGE_NAME)
VERSION := $(shell cat VERSION)

help: ## Show this help message
	@echo "Usage: make [target]"
	@echo ""
	@echo "Targets:"
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  %-15s %s\n", $$1, $$2}'

install: ## Install the package
	pip install -e .
	{%- if project_type == 'application' %}
	@echo "For FastAPI support: pip install -e .[api]"
	{%- endif %}

dev: ## Install development dependencies
	pip install -e .[dev]
	{%- if project_type == 'application' %}
	pip install -e .[api]
	{%- endif %}
	pre-commit install

test: ## Run tests
	pytest tests/ -v --cov=$(PACKAGE_NAME) --cov-report=term-missing

lint: ## Run linters
	ruff check .
	black --check .

format: ## Format code
	ruff check --fix .
	black .

type-check: ## Run type checking
	mypy src/$(PACKAGE_NAME)

ci: ## Run full CI pipeline
	./scripts/ci

bootstrap: ## Bootstrap development environment
	./scripts/bootstrap --install

{%- if project_type == 'application' %}

run: ## Run the FastAPI application
	uvicorn $(PACKAGE_NAME).api:app --reload --host 0.0.0.0 --port 8000

run-prod: ## Run the FastAPI application in production mode
	uvicorn $(PACKAGE_NAME).api:app --host 0.0.0.0 --port 8000 --workers 4

{%- endif %}

{%- if project_type == 'cli' %}

run: ## Run the CLI
	python -m $(PACKAGE_NAME).cli --help

{%- endif %}

docker-build: ## Build Docker image
	@chmod +x scripts/docker-build.sh
	@./scripts/docker-build.sh

docker-run: ## Run Docker container
	docker run --rm -it \
		--env-file .env \
		{%- if project_type == 'application' %}
		-p 8000:8000 \
		{%- endif %}
		$(DOCKER_IMAGE):latest

docker-push: ## Push Docker image to JFrog
	docker push $(DOCKER_IMAGE):$(VERSION)
	docker push $(DOCKER_IMAGE):latest

docker-compose-up: ## Start services with docker-compose
	docker-compose up -d

docker-compose-down: ## Stop services with docker-compose
	docker-compose down

k8s-deploy: ## Deploy to Kubernetes
	kubectl apply -f k8s/

k8s-delete: ## Delete from Kubernetes
	kubectl delete -f k8s/

k8s-logs: ## View Kubernetes logs
	kubectl logs -n $(PACKAGE_NAME) -l app=$(PACKAGE_NAME) -f

{%- if project_type == 'library' %}

build: ## Build distribution packages
	python -m build

publish-test: ## Publish to test PyPI
	twine upload --repository testpypi dist/*

publish: ## Publish to JFrog Artifactory
	twine upload --repository-url $(TWINE_REPOSITORY_URL) dist/*

{%- endif %}

clean: ## Clean build artifacts
	rm -rf build dist *.egg-info
	rm -rf .pytest_cache .coverage .mypy_cache .ruff_cache
	find . -type d -name __pycache__ -exec rm -rf {} +
	find . -type f -name "*.pyc" -delete

version: ## Show current version
	@echo $(VERSION)

# Default target
.DEFAULT_GOAL := help
