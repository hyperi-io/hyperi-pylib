# Multi-stage build for {{ project_name }}
# Python version extracted from pyproject.toml requires-python
ARG PYTHON_VERSION=3.11
FROM python:${PYTHON_VERSION}-slim as builder

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /build

# Copy requirements first for better caching
COPY pyproject.toml .
COPY src/ src/

# Install dependencies and build package
RUN pip install --no-cache-dir build && \
    python -m build --wheel && \
    pip wheel --no-cache-dir --wheel-dir /wheels .[{% if project_type == 'application' %}api{% endif %}]

# Runtime stage
FROM python:${PYTHON_VERSION}-slim

# Create non-root user
RUN useradd -m -u 1000 appuser

# Set working directory
WORKDIR /app

# Copy wheels from builder
COPY --from=builder /wheels /wheels

# Install runtime dependencies
RUN pip install --no-cache-dir --no-index --find-links /wheels /wheels/*.whl && \
    rm -rf /wheels

# Copy application code
COPY --chown=appuser:appuser . .

# Switch to non-root user
USER appuser

{%- if project_type == 'application' %}
# Expose API port
EXPOSE 8000

# Health check for FastAPI (only if API dependencies are installed)
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD python -c "import sys; sys.exit(0)" || exit 1

# Run application - defaults to FastAPI if available, otherwise runs tests
CMD ["sh", "-c", "if python -c 'import {{ package_name }}.api' 2>/dev/null; then python -m uvicorn {{ package_name }}.api:app --host 0.0.0.0 --port 8000; else python -m pytest tests/ -v; fi"]

{%- elif project_type == 'cli' %}
# Set entrypoint to CLI
ENTRYPOINT ["python", "-m", "{{ package_name }}.cli"]
CMD ["--help"]

{%- else %}
# Library container - runs tests by default
CMD ["python", "-m", "pytest", "tests/"]
{%- endif %}
