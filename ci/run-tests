#!/usr/bin/env bash
#
# Run all hyperlib tests with logging
#

set -euo pipefail

cd "$(dirname "$0")/.."

# Ensure logs directory exists
mkdir -p logs

# Rename existing log if it exists
if [ -f "logs/all-tests.log" ]; then
    TIMESTAMP=$(date -r "logs/all-tests.log" +%Y%m%d-%H%M%S 2>/dev/null || stat -c %y "logs/all-tests.log" | cut -d' ' -f1,2 | tr ' ' '-' | tr ':' '-' | cut -d'-' -f1-4)
    mv "logs/all-tests.log" "logs/all-tests-${TIMESTAMP}.log"
    echo "Renamed previous log to all-tests-${TIMESTAMP}.log"
fi

# Run tests
.venv-ci/bin/pytest tests/ -v --tb=short 2>&1 | tee logs/all-tests.log

echo ""
echo "Test log saved to logs/all-tests.log"
