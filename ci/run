#!/usr/bin/env python3
"""
Core CI entrypoint - Simple .d directory runner.

This script runs all scripts in ci/ directories in sorted order.
It ensures bootstrap has run first (to install tools and dependencies).

Usage:
- ./ci/run              # Run all CI checks
- ./ci/run check        # Same as above
- ./ci/run --help       # Show help

CI Directory Discovery:
1. Common ci.d/: ci/common/ci.d/ - Language-agnostic checks
2. Language ci.d/: ci/python/ci.d/ - Language-specific checks
3. Custom ci.d/: Can be added via CUSTOM_CI_D env var

All scripts are run in sorted order with "check" action.
"""

import argparse
import os
import subprocess
import sys
from pathlib import Path

# Get project root - simple approach
# This script runs from ci/run, so project root is parent of ci/
SCRIPT_PATH = Path(__file__).resolve()
CI_DIR = SCRIPT_PATH.parent
PROJECT_ROOT = CI_DIR.parent


def find_ci_directories() -> list:
    """Find all ci.d directories to process."""
    ci_dirs = []

    # Common ci.d (language-agnostic)
    common_ci_d = CI_DIR / "common" / "ci.d"
    if common_ci_d.exists():
        ci_dirs.append(("common", common_ci_d))

    # Language-specific ci.d (Python in this case)
    python_ci_d = CI_DIR / "python" / "ci.d"
    if python_ci_d.exists():
        ci_dirs.append(("python", python_ci_d))

    # Custom ci.d (from env)
    if os.environ.get("CUSTOM_CI_D"):
        custom_ci_d = Path(os.environ["CUSTOM_CI_D"])
        if custom_ci_d.exists():
            ci_dirs.append(("custom", custom_ci_d))

    return ci_dirs


def find_scripts(ci_dir: Path) -> list:
    """Find all executable scripts in a ci.d directory."""
    if not ci_dir.exists():
        return []

    scripts = []
    for item in sorted(ci_dir.iterdir()):
        # Skip non-files
        if not item.is_file():
            continue

        # Skip editor backups and config files
        if item.suffix in [".swp", ".bak", "~", ".yaml", ".yml", ".json", ".toml", ".md"]:
            continue

        # Only include .py, .sh, or executable files
        if not (item.suffix in [".py", ".sh"] or os.access(item, os.X_OK)):
            continue

        scripts.append(item)

    return scripts


def handle_clean_action(args) -> int:
    """Handle the clean action - remove build artifacts."""
    print("\nCleaning build artifacts...")

    patterns = [
        "dist/",
        "build/",
        "*.egg-info",
        "__pycache__/",
        ".pytest_cache/",
        ".mypy_cache/",
        ".ruff_cache/",
        "*.pyc",
        "*.pyo",
        ".coverage",
        "htmlcov/",
    ]

    import shutil
    import glob

    removed = []
    for pattern in patterns:
        if "/" in pattern:
            # Directory pattern
            dir_path = PROJECT_ROOT / pattern.rstrip("/")
            if dir_path.exists():
                if args.dry_run:
                    print(f"Would remove: {dir_path}")
                else:
                    shutil.rmtree(dir_path)
                    removed.append(str(dir_path))
                    print(f"Removed: {dir_path}")
        else:
            # File pattern
            for item in PROJECT_ROOT.rglob(pattern):
                if args.dry_run:
                    print(f"Would remove: {item}")
                else:
                    if item.is_dir():
                        shutil.rmtree(item)
                    else:
                        item.unlink()
                    removed.append(str(item))

    if removed and not args.dry_run:
        print(f"\n✓ Cleaned {len(removed)} items")
    elif args.dry_run:
        print("\n✓ Dry run complete")
    else:
        print("\n✓ No artifacts to clean")

    return 0


def handle_clean_commit_action(args) -> int:
    """Handle the clean-commit action - remove AI attribution from last commit."""
    print("\nCleaning AI attribution from last commit...")

    # Find the clean-commit script
    script_path = CI_DIR / "python" / "ci.d" / "15-clean-commit-message.py"
    if not script_path.exists():
        print(f"\nERROR: Script not found: {script_path}")
        return 1

    # Use ci/.venv Python
    venv_python = CI_DIR / ".venv" / "bin" / "python"
    if not venv_python.exists():
        print("\nERROR: ci/.venv not found!")
        print("Run: ./ci/bootstrap --install")
        return 1

    # Run the script
    result = subprocess.run([str(venv_python), str(script_path)], cwd=PROJECT_ROOT)
    return result.returncode


def run_script(script: Path, action: str = "check") -> int:
    """Run a single CI script."""
    print(f"\n{'='*60}")
    print(f"Running: {script.name}")
    print(f"{'='*60}")

    # CRITICAL: CI scripts MUST use ci/.venv Python (FAIL HARD if missing)
    venv_python = CI_DIR / ".venv" / "bin" / "python"
    if not venv_python.exists():
        print("\nERROR: ci/.venv not found!")
        print("CI scripts require ci/.venv to be set up.")
        print("Run: ./ci/bootstrap --install")
        return 1

    # Determine how to run the script
    if script.suffix == ".py":
        cmd = [str(venv_python), str(script), action]
    elif script.suffix == ".sh":
        cmd = ["bash", str(script), action]
    else:
        cmd = [str(script), action]

    result = subprocess.run(cmd, cwd=PROJECT_ROOT)
    return result.returncode


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="CI runner with language-agnostic and language-specific checks",
        epilog="""
Examples:
  ./ci/run check        # Run all checks (lint, test, type-check)
  ./ci/run build        # Build package locally
  ./ci/run release      # Full release (version, tag, build)
  ./ci/run publish      # Full release + push to remote (triggers GitHub Actions)
  ./ci/run clean        # Remove build artifacts
  ./ci/run clean-commit # Remove AI attribution from last commit

  # JFrog publishing (local):
  ./ci/run --script 80-build.py publish              # Publish to JFrog (auto-detect creds)
  ./ci/run --script 80-build.py publish --no-publish # Skip JFrog publishing
  JFROG_PUBLISH=false ./ci/run build                # Build without publishing
        """
    )
    parser.add_argument(
        "action",
        nargs="?",
        default="check",
        choices=["check", "install", "lint", "test", "build", "release", "publish", "clean", "clean-commit", "all"],
        help="Action to perform (default: check)"
    )
    parser.add_argument(
        "--script",
        metavar="BASENAME",
        help="Run only this script from ci.d/ (e.g., 80-build.py)"
    )
    parser.add_argument(
        "--continue-on-error",
        action="store_true",
        help="Continue running even if a script fails"
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Force action (e.g., force release without CI check)"
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would happen without doing it"
    )
    parser.add_argument(
        "--push",
        action="store_true",
        help="Push changes to remote after release (use with release action)"
    )
    parser.add_argument(
        "--no-publish",
        action="store_true",
        help="Skip JFrog publishing (sets JFROG_PUBLISH=false)"
    )
    args = parser.parse_args()

    print("="*60)
    print("CI Runner")
    print("="*60)

    # Handle special actions first
    if args.action == "clean":
        return handle_clean_action(args)

    if args.action == "clean-commit":
        return handle_clean_commit_action(args)

    # Handle publish as shorthand for release --push
    if args.action == "publish":
        args.action = "release"
        args.push = True

    # Ensure bootstrap has run (except for clean which doesn't need it)
    bootstrap_script = CI_DIR / "bootstrap"
    if bootstrap_script.exists():
        print("\n[Ensuring bootstrap has run...]")
        result = subprocess.run(
            [str(bootstrap_script)],
            cwd=PROJECT_ROOT
        )
        if result.returncode != 0:
            print("\nERROR: Bootstrap failed. Run: ./ci/bootstrap --install")
            return 1
    else:
        print("\nWARNING: No bootstrap script found, skipping bootstrap check")

    # Set environment variables for flags
    if args.force:
        os.environ["FORCE_RELEASE"] = "1"
        os.environ["CI_FORCE"] = "1"
    if args.dry_run:
        os.environ["DRY_RUN"] = "1"
        os.environ["CI_DRY_RUN"] = "1"
    if args.push:
        os.environ["CI_PUSH"] = "1"
    if args.no_publish:
        os.environ["JFROG_PUBLISH"] = "false"

    # Find all ci.d directories
    ci_dirs = find_ci_directories()
    if not ci_dirs:
        print("\nNo ci.d directories found")
        return 0

    print(f"\nCI directories:")
    for label, ci_dir in ci_dirs:
        print(f"  - {label}: {ci_dir}")

    # Handle --script option: run single script only
    if args.script:
        script_basename = args.script
        print(f"\n{'='*60}")
        print(f"Running single script: {script_basename}")
        print(f"{'='*60}")

        # Search for script in all ci.d directories
        script_found = False
        for label, ci_dir in ci_dirs:
            script_path = ci_dir / script_basename
            if script_path.exists() and script_path.is_file():
                # Validate it's a .py or .sh file
                if script_path.suffix not in [".py", ".sh"]:
                    print(f"\nERROR: {script_basename} must be a .py or .sh file")
                    return 1

                print(f"\nFound in [{label}]: {script_path}")
                returncode = run_script(script_path, args.action)
                script_found = True

                if returncode != 0:
                    print(f"\nERROR: {script_basename} failed with code {returncode}")
                    return returncode
                else:
                    print(f"\n✓ {script_basename} completed successfully")
                    return 0

        if not script_found:
            print(f"\nERROR: Script '{script_basename}' not found in any ci.d directory")
            print("\nAvailable scripts:")
            for label, ci_dir in ci_dirs:
                scripts = find_scripts(ci_dir)
                if scripts:
                    print(f"\n[{label}]:")
                    for s in scripts:
                        print(f"  - {s.name}")
            return 1

    # Run all scripts in order
    failed_scripts = []
    for label, ci_dir in ci_dirs:
        scripts = find_scripts(ci_dir)
        if not scripts:
            continue

        print(f"\n{'='*60}")
        print(f"{label.upper()} CI Scripts")
        print(f"{'='*60}")

        for script in scripts:
            returncode = run_script(script, args.action)
            if returncode != 0:
                failed_scripts.append((label, script.name, returncode))
                if not args.continue_on_error:
                    print(f"\nERROR: {script.name} failed with code {returncode}")
                    return returncode

    # Summary
    print(f"\n{'='*60}")
    print("CI Summary")
    print(f"{'='*60}")

    if failed_scripts:
        print(f"\n{len(failed_scripts)} script(s) failed:")
        for label, name, code in failed_scripts:
            print(f"  - [{label}] {name} (exit code: {code})")
        return 1
    else:
        print("\n✓ All CI checks passed")
        return 0


if __name__ == "__main__":
    sys.exit(main())