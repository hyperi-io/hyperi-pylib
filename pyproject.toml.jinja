[build-system]
requires = ["setuptools>=64.0.0", "wheel", "pip>=22.1"]
build-backend = "setuptools.build_meta"

# HyperSec private PyPI repository configuration
# Authentication via environment variables:
#   export PIP_INDEX_URL=https://username:password@hypersec.jfrog.io/artifactory/api/pypi/hypersec-pypi-local/simple
#   export PIP_EXTRA_INDEX_URL=https://pypi.org/simple
# Or store in .env file (never commit to git)

[project]
name = "{{ package_name }}"
version = "3.20.2"
authors = [
    {name = "Template Author", email = "template@example.com"},
]
description = "Python Package Template - Replace with your description"
readme = "README.md"
{% if license == 'apache-2.0' %}
license = "Apache-2.0"
{% endif %}
license-files = ["LICENSE"]
# >>> HSF:EXTRA-PROJECT-FIELDS:BEGIN
# Child templates may append additional project fields (key = "value") here.
# This block is used by additive overlays and must remain present.
# <<< HSF:EXTRA-PROJECT-FIELDS:END
requires-python = ">=3.11"
classifiers = [
    "Development Status :: 5 - Production/Stable",
    "Intended Audience :: Developers",
    "Intended Audience :: System Administrators",
    "Topic :: System :: Logging",
    "Topic :: System :: Systems Administration", 
    "Topic :: Software Development :: Libraries :: Python Modules",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
    "Programming Language :: Python :: 3.13",
    "Programming Language :: Python :: 3 :: Only",
    "Operating System :: OS Independent",
]
keywords = ["template", "python", "package", "development"]
dependencies = [
    # Core dependencies for all project types
    "dynaconf>=3.2.0",  # Configuration management
    "loguru>=0.7.0",    # Professional logging
    {%- if project_type == 'cli' %}
    "click>=8.1.0",     # CLI framework
    "rich>=13.0.0",     # Rich terminal output
    {%- endif %}
    {%- if project_type == 'daemon' %}
    "aiofiles>=23.0.0", # Async file operations
    "watchdog>=3.0.0",  # File system monitoring
    {%- if include_api %}
    "fastapi>=0.100.0",      # REST API framework
    "uvicorn[standard]>=0.23.0",  # ASGI server
    "pydantic>=2.0.0",       # Data validation
    "httpx>=0.24.0",         # HTTP client
    {%- endif %}
    {%- endif %}
    {%- if project_type == 'package' %}
    # Package has minimal dependencies by default
    # Add your package-specific dependencies here
    {%- endif %}
]

[project.optional-dependencies]
enhanced = [
    # Add optional enhanced dependencies here
    # "pandas>=2.0.0",    # Data analysis
    # "requests>=2.31.0",  # HTTP client
    # "numpy>=1.24.0",     # Scientific computing
]
dev = [
    "nox>=2024.0.0",         # Task automation and testing
    "pytest>=8.0.0",         # Modern test framework
    "pytest-cov>=5.0.0",     # Test coverage reporting
    "ruff>=0.1.0",           # Fast Python linter (replaces flake8)
    "black>=24.0.0",         # Code formatting
    "mypy>=1.8.0",           # Static type checking
    "vermin>=1.6.0",         # Python version detection and automation
    "python-dotenv>=1.0.0",  # Environment configuration
    "pyyaml>=6.0.1",         # YAML configuration support
    "pre-commit>=3.0.0",     # Git pre-commit hooks
    "isort>=5.12.0",         # Import sorting
    "requests>=2.31.0",      # For download_datasets script
    {%- if project_type == 'package' %}
    "build>=1.0.0",          # Build backend for packages
    "twine>=5.0.0",          # PyPI upload tool
    {%- endif %}
]
docs = [
    "sphinx>=8.0.0",          # Documentation generator
    "sphinx-rtd-theme>=3.0.0", # Read the Docs theme
    "myst-parser>=3.0.0",     # Markdown parser for Sphinx
    "sphinx-autobuild>=2024.0.0", # Live reload during development
]

[project.urls]
Homepage = "https://github.com/hypersec-io/{{ package_name }}"
Documentation = "https://hypersec-io.github.io/{{ package_name }}/"
Repository = "https://github.com/hypersec-io/{{ package_name }}"
"Bug Reports" = "https://github.com/hypersec-io/{{ package_name }}/issues"
Changelog = "https://github.com/hypersec-io/{{ package_name }}/blob/main/CHANGELOG.md"

{%- if project_type == 'cli' %}

[project.scripts]
{{ project_name }} = "{{ package_name }}.cli:main"
{%- endif %}

{%- if project_type == 'daemon' %}

[project.scripts]
{{ project_name }} = "{{ package_name }}.daemon:run"
{{ project_name }}-daemon = "{{ package_name }}.daemon:run"
{%- endif %}

[tool.setuptools]
package-dir = {"" = "src"}

[tool.setuptools.packages.find]
where = ["src"]
include = ["{{ package_name }}*"]
exclude = ["tests*"]

# Black code formatting
[tool.black]
line-length = 88
target-version = ['py311']
# Future target versions (uncomment when Black supports them):
# target-version = ['py311', 'py312', 'py313']  # Multi-version example
# Note: Black will add support for Python 3.26+ (calendar versioning) as py326, py327, py328
include = '\.pyi?$'
extend-exclude = '''
/(
  # directories
  \.eggs
  | \.git
  | \.hg
  | \.mypy_cache
  | \.tox
  | \.venv
  | build
  | dist
  | \.tmp
  | logs
)/
'''

# MyPy type checking
[tool.mypy]
python_version = "3.11"  # Matches minimum supported version
warn_return_any = true
warn_unused_configs = true
# Start less strict for generated projects
disallow_untyped_defs = false
disallow_incomplete_defs = false
check_untyped_defs = true
disallow_untyped_decorators = false
no_implicit_optional = true
warn_redundant_casts = true
warn_unused_ignores = false
warn_no_return = true
warn_unreachable = false
strict_equality = true
# Ignore missing imports for common dev dependencies
ignore_missing_imports = true
# Exclude scripts from strict typing
exclude = [
    "scripts/",
    "noxfile.py",
    "tests/test_deploy_e2e.py"
]

# pytest configuration
[tool.pytest.ini_options]
minversion = "8.0.0"
addopts = "-ra -q --strict-markers --strict-config"
testpaths = ["tests"]
python_files = ["test_*.py", "*_test.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]
markers = [
    "slow: marks tests as slow (deselect with '-m \"not slow\"')",
    "integration: marks tests as integration tests",
    "e2e: marks end-to-end deployment tests (Set RUN_E2E=1 to run)",
]

# Coverage configuration  
[tool.coverage.run]
source = ["{{ package_name }}"]
omit = [
    "*/tests/*",
    "*/test_*",
    "*/.venv/*",
    "*/venv/*",
]

[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "def __repr__",
    "if self.debug:",
    "if settings.DEBUG",
    "raise AssertionError",
    "raise NotImplementedError",
    "if 0:",
    "if __name__ == .__main__.:",
    "class .*\\bProtocol\\):",
    "@(abc\\.)?abstractmethod",
]

# Bandit security linting configuration
[tool.bandit]
exclude_dirs = [
    "tests",
    "test", 
    ".venv",
    "venv",
    ".tox",
    "build",
    "dist",
    "data/samples"
]
skips = ["B101", "B603"]

# Semantic Release Configuration
[tool.semantic_release]
# Git tags are the source of truth for versioning
# semantic-release will update files to match calculated version from tags + commits
version_variables = [
    "src/{{ package_name }}/__init__.py:__version__"
]
version_toml = [
    "pyproject.toml:project.version"
]
# Tag format and versioning source
tag_format = "v{version}"
# Note: VERSION file is updated by CI/CD workflow, not semantic-release directly

# Branch and commit settings
[tool.semantic_release.branches.main]
match = "main"

[tool.semantic_release.commit_parser_options]
allowed_tags = ["feat", "fix", "docs", "style", "refactor", "perf", "test", "chore", "ci", "build"]
minor_tags = ["feat"]
patch_tags = ["fix", "perf", "refactor"]

# CI/CD settings
build_command = "python -m build"
upload_to_pypi = false
upload_to_release = true
commit_message = "chore(release): {version} [skip ci]\n\nAutomatically generated by python-semantic-release"
commit_parser = "conventional"
major_on_zero = false
allow_zero_version = false

# Assets to include in releases  
assets = [
    # >>> HSF:ASSETS:BEGIN
    "dist/*.whl",
    "dist/*.tar.gz"
    # <<< HSF:ASSETS:END
]

[tool.bandit.assert_used]
# Allow asserts in test files
skips = ["*test*.py", "*tests*.py"]

# pip-audit dependency vulnerability scanner
# Configuration via command line arguments in CI/CD
prerelease = false

[tool.semantic_release.changelog]
template_dir = "templates"
exclude_commit_patterns = [
    "^chore:",
    "^docs:",
    "^style:",
    "^refactor:",
    "^test:",
    "^build:",
]

[tool.semantic_release.changelog.default_templates]
changelog_file = "CHANGELOG.md"

[tool.semantic_release.commit_author]
env = "GIT_COMMITTER_NAME"
default = "semantic-release <semantic-release>"

[tool.semantic_release.publish]
dist_glob_patterns = ["dist/*"]
upload_to_vcs_release = true
